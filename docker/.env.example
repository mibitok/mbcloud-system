#===============================================================================
# Immich Environment Variables - mbcloud NAS
# ИНСТРУКЦИЯ:
#   1. Скопируйте этот файл: cp .env.example .env
#   2. Откройте .env: nano .env
#   3. Замените DB_PASSWORD на надёжный пароль (можно сгенерировать: openssl rand -hex 16)
#   4. Запустите: docker compose up -d
#===============================================================================

# 🔐 DATABASE (ОБЯЗАТЕЛЬНО — смените пароль!)
# Генерация надёжного пароля: openssl rand -hex 16
DB_PASSWORD=change_this_to_secure_password_12345
DB_USERNAME=immich
DB_DATABASE_NAME=immich

# 📁 PATHS (не меняйте без необходимости)
# Эти пути должны совпадать с томами в docker-compose.yml
DB_DATA_LOCATION=/DATA/immich-postgres
UPLOAD_LOCATION=/DATA/immich-upload
LIBRARY_LOCATION=/DATA/immich-library

# 🌍 TIMEZONE
# Список: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=Europe/Moscow

# 🤖 MACHINE LEARNING (опционально)
# Модель для распознавания лиц и объектов
MACHINE_LEARNING_MODEL_NAME=ViT-B-32__openai

# 🗑️ TRASH SETTINGS
# Дни хранения в корзине перед окончательным удалением
TRASH_DAYS=30

# 📊 TELEMETRY (опционально)
# Отключить сбор анонимной статистики
# IMMICH_TELEMETRY_INCLUDE=false

# 🔧 ADVANCED (не меняйте, если не уверены)
# DB_PORT=5432
# REDIS_HOSTNAME=immich_redis
# IMMICH_HOST=0.0.0.0
# IMMICH_PORT=2283

#===============================================================================
# ПРИМЕР ИСПОЛЬЗОВАНИЯ:
#===============================================================================
# 1. Создайте .env из шаблона:
#    cp .env.example .env
#
# 2. Отредактируйте пароль:
#    nano .env
#    # Замените: DB_PASSWORD=change_this_to_secure_password_12345
#    # На: DB_PASSWORD=a1b2c3d4e5f6... (надёжный пароль)
#
# 3. Создайте папки и настройте права:
#    sudo mkdir -p /DATA/immich-{upload,library,postgres}
#    sudo chown -R 999:999 /DATA/immich-postgres
#    sudo chown -R $USER:$USER /DATA/immich-{upload,library}
#
# 4. Запустите Immich:
#    docker compose up -d
#
# 5. Откройте в браузере:
#    👉 http://192.168.1.105:2283
#
# 6. Создайте аккаунт (первый пользователь = администратор)
#===============================================================================

# ============================================================================
# mbcloud NAS - Immich Environment Variables Template
# Скопируйте этот файл в .env и отредактируйте значения:
#   cp .env.example .env
#   nano .env
# ============================================================================

# 🗄️ Database
# Пароль для PostgreSQL (смените на надёжный!)
# Генерация пароля: openssl rand -hex 16
DB_PASSWORD=change_this_to_secure_password_12345

# 🌍 Timezone
# Список: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=Europe/Moscow

# 📁 Paths (не меняйте, если не уверены)
# Пути внутри контейнеров
UPLOAD_LOCATION=/usr/src/app/upload
# Монтируются из docker-compose.yml

# 🔐 Security
# Не используйте дефолтные значения в продакшене!
# Для локальной сети можно оставить как есть
IMMICH_MACHINE_ID=mbcloud-nas

# 🌐 Network
# Порт веб-интерфейса (не меняйте, если не конфликтует)
IMMICH_PORT=2283

# 🗑️ Trash
# Дни хранения в корзине перед удалением
TRASH_DAYS=30

# 🤖 Machine Learning
# Модель распознавания лиц (оставьте по умолчанию)
MACHINE_LEARNING_MODEL_NAME=ViT-B-32__openai

# 📊 Monitoring
# Включить сбор метрик для Prometheus (опционально)
# IMMICH_TELEMETRY_INCLUDE=false

# ============================================================================
# 🛠️ Дополнительные настройки (продвинутые)
# ============================================================================

# 🗄️ PostgreSQL tuning (для 2-4 ГБ ОЗУ)
# DB_WORK_MEM=4MB
# DB_MAINTENANCE_WORK_MEM=64MB

# 🤖 ML ресурсы (ограничение для Raspberry Pi)
# OMP_NUM_THREADS=2
# MKL_NUM_THREADS=2

# 📦 Redis
# REDIS_PASSWORD=  # Оставьте пустым для локальной сети

# ============================================================================
# 📝 Пример использования:
# ============================================================================
# 1. Скопируйте шаблон:
#    cp .env.example .env
#
# 2. Отредактируйте .env:
#    nano .env
#    # Смените DB_PASSWORD на надёжный пароль
#
# 3. Запустите Immich:
#    docker compose up -d
#
# 4. Откройте в браузере:
#    http://192.168.1.106:2283
# ============================================================================
